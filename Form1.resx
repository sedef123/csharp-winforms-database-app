        private void LoadFilmsToGrid()
        {
            DataTable dt = new DataTable();

            using (NpgsqlConnection conn = new NpgsqlConnection(connectionString))
            {
                try
                {
                    conn.Open();
                    string sql = "SELECT film_id, title, rental_rate, rental_duration FROM \"Film\" ORDER BY film_id;";

                    using (NpgsqlDataAdapter da = new NpgsqlDataAdapter(sql, connectionString))
                    {
                        da.Fill(dt);
                    }
                    dataGridViewFilm.DataSource = dt;
                }
                catch (Exception ex)
                {
                    MessageBox.Show("Film Listeleme Hatası: " + ex.Message);
                }
            }
        }

        private void btnFilmList_Click(object sender, EventArgs e)
