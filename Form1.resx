        private void btnCustomerInsert_Click(object sender, EventArgs e)
        {
            if (cmbCustomerType == null || cmbCustomerType.SelectedItem == null)
            {
                MessageBox.Show("Lütfen müşteri tipini seçiniz.", "Giriş Hatası");
                return;
            }

            if (!int.TryParse(txtCustomerId.Text, out int customerId) ||
                !short.TryParse(txtCustomerStoreId.Text, out short storeId) ||
                string.IsNullOrWhiteSpace(txtCustomerName.Text))
            {
                MessageBox.Show("Lütfen tüm zorunlu alanları geçerli giriniz.", "Giriş Hatası");
                return;
            }

            string fullName = txtCustomerName.Text;
            string customerType = cmbCustomerType.SelectedItem.ToString();

            using (NpgsqlConnection conn = new NpgsqlConnection(connectionString))
            {
                NpgsqlTransaction transaction = null;
                try
                {
                    conn.Open();
                    transaction = conn.BeginTransaction();

                    string customerSql = "INSERT INTO \"Customer\" (customer_id, full_name, store_id, customer_type) " +
                                         "VALUES (@id, @name, @store, @type)";

                    using (NpgsqlCommand cmd = new NpgsqlCommand(customerSql, conn, transaction))
                    {
                        cmd.Parameters.AddWithValue("@id", customerId);
                        cmd.Parameters.AddWithValue("@name", fullName);
                        cmd.Parameters.AddWithValue("@store", storeId);
                        cmd.Parameters.AddWithValue("@type", customerType);
                        cmd.ExecuteNonQuery();
                    }

                    string subTypeSql = "";
                    string message = "";

                    switch (customerType)
                    {
                        case "Normal":
                            subTypeSql = "INSERT INTO \"Normal_Customer\" (customer_id) VALUES (@id)";
                            message = "Normal Müşteri";
                            break;
                        case "Gold":
                            subTypeSql = "INSERT INTO \"Gold_Customer\" (customer_id) VALUES (@id)";
                            message = "Gold Müşteri";
                            break;
                        case "Platinum":
                            subTypeSql = "INSERT INTO \"Platinum_Customer\" (customer_id) VALUES (@id)";
                            message = "Platinum Müşteri";
                            break;
                        default:
                            throw new Exception("Geçersiz müşteri tipi seçildi.");
                    }

                    using (NpgsqlCommand subTypeCmd = new NpgsqlCommand(subTypeSql, conn, transaction))
                    {
                        subTypeCmd.Parameters.AddWithValue("@id", customerId);
                        subTypeCmd.ExecuteNonQuery();
                    }

                    transaction.Commit();
                    MessageBox.Show($"{message} başarıyla eklendi.", "Başarılı");
                    LoadCustomersToGrid();
                }
                catch (Exception ex)
                {
                    if (transaction != null)
                    {
                        transaction.Rollback();
                    }
                    MessageBox.Show("Müşteri Ekleme Hatası (İşlem Geri Alındı): " + ex.Message, "Hata");
                }
            }
        }
        private void btnCustomerUpdate_Click(object sender, EventArgs e)
        {
            if (!int.TryParse(txtCustomerId.Text, out int customerId) ||
                !short.TryParse(txtCustomerStoreId.Text, out short storeId))
            {
                MessageBox.Show("Lütfen geçerli sayısal değerler giriniz.", "Giriş Hatası");
                return;
            }

            string fullName = txtCustomerName.Text;
            string customerType = cmbCustomerType.SelectedItem.ToString(); 

            using (NpgsqlConnection conn = new NpgsqlConnection(connectionString))
            {
                NpgsqlTransaction transaction = null;
                try
                {
                    conn.Open();
                    transaction = conn.BeginTransaction();
  
                    string sql = "UPDATE \"Customer\" SET full_name = @name, store_id = @store, customer_type = @type WHERE customer_id = @id";

                    using (NpgsqlCommand cmd = new NpgsqlCommand(sql, conn, transaction))
                    {
                        cmd.Parameters.AddWithValue("@id", customerId);
                        cmd.Parameters.AddWithValue("@name", fullName);
                        cmd.Parameters.AddWithValue("@store", storeId);
                        cmd.Parameters.AddWithValue("@type", customerType);

                        int affectedRows = cmd.ExecuteNonQuery();

                        if (affectedRows > 0)
                        {
                            transaction.Commit();
                            MessageBox.Show("Müşteri temel bilgileri başarıyla güncellendi.", "Başarılı");
                            LoadCustomersToGrid();
                        }
                        else
                        {
                            transaction.Rollback();
                            MessageBox.Show("Güncellenecek müşteri bulunamadı.", "Uyarı");
                        }
                    }
                }
                catch (Exception ex)
                {
                    if (transaction != null) transaction.Rollback();
                    MessageBox.Show("Güncelleme Hatası: " + ex.Message, "Hata");
                }
            }
        }
