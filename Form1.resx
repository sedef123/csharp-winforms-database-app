        private void btnFilmInsert_Click(object sender, EventArgs e)
        {
            if (!int.TryParse(txtFilmId.Text, out int filmId) ||
                !decimal.TryParse(txtRentalRate.Text, NumberStyles.Any, CultureInfo.InvariantCulture, out decimal rentalRate) ||
                !short.TryParse(txtRentalDuration.Text, out short duration))
            {
                MessageBox.Show("Lütfen geçerli sayısal değerler (ID, Ücret, Süre) giriniz.", "Giriş Hatası");
                return;
            }

            string title = txtTitle.Text;

            using (NpgsqlConnection conn = new NpgsqlConnection(connectionString))
                try
                {
                    conn.Open();
                    string sql = "INSERT INTO \"Film\" (film_id, title, rental_rate, rental_duration) VALUES (@id, @title, @rate, @duration)";

                    using (NpgsqlCommand cmd = new NpgsqlCommand(sql, conn))
                    {
                        cmd.Parameters.AddWithValue("@id", filmId);
                        cmd.Parameters.AddWithValue("@title", title);
                        cmd.Parameters.AddWithValue("@rate", rentalRate);
                        cmd.Parameters.AddWithValue("@duration", duration);

                        cmd.ExecuteNonQuery();
                        MessageBox.Show("Film başarıyla eklendi.", "Başarılı");
                        LoadFilmsToGrid();
                    }
                }
                catch (Exception ex)
                {
                    MessageBox.Show("Ekleme Hatası: " + ex.Message, "Hata");
                }

        }

